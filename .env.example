# Google Cloud Document AI 설정 (영수증 OCR용)
GOOGLE_APPLICATION_CREDENTIALS=./receipt_model/your-service-account-key.json
PROJECT_ID=your-project-id
PROCESSOR_ID=your-processor-id
LOCATION=us

# Google Gemini API (음식 분류 폴백 + 영수증 2차 정제 + 냉장고 감지 공용)
GEMINI_API_KEY=your-gemini-api-key

# AI 서버 인증 토큰 (백엔드 팀에게 전달, python3 -c "import secrets; print(secrets.token_hex(32))" 로 생성)
AI_SECRET_TOKEN=your-secret-token

# Gemini API 타임아웃 (선택사항 — 설정 안 하면 코드 기본값 30초 적용)
# GEMINI_TIMEOUT=30
